# ──────────────────────────────────────────────────────────────────────────────
# sleepctl dashboard — environment configuration
#
# Copy this file to .env before running `make up`:
#   cp .env.example .env
#
# `make up` does that copy automatically if .env doesn't exist, and will
# also auto-generate a strong DASHBOARD_PASSWORD if it is still "changeme".
# ──────────────────────────────────────────────────────────────────────────────

# ── Auth ──────────────────────────────────────────────────────────────────────

# Single-user credentials for the dashboard login.
# `make up` replaces the placeholder password with a random one on first run.
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=changeme

# JWT signing secret.  Leave blank to auto-generate on first container start;
# the secret is then persisted to the `sleepdata` volume at /data/.jwt_secret
# so it survives restarts.  You may set an explicit value here if you prefer
# full control (run: python3 -c "import secrets; print(secrets.token_hex(32))").
JWT_SECRET=

# ── CORS ─────────────────────────────────────────────────────────────────────

# Comma-separated list of allowed origins for the FastAPI CORS middleware.
# "*" is fine for a local-only deployment.  If you add a public tunnel
# (Tailscale / Cloudflare) add its origin here.
CORS_ORIGINS=*

# ── Timezone ──────────────────────────────────────────────────────────────────

# Set to your local zone so sleep-window timestamps display correctly.
# Examples: America/New_York  America/Los_Angeles  Europe/London  Asia/Tokyo
TZ=America/New_York

# ── Optional: database path override ─────────────────────────────────────────
# Defaults to /data/sleepctl.db inside the container (backed by the sleepdata
# named volume).  Only change this if you want to mount a host path instead.
# SLEEPCTL_DB=/data/sleepctl.db

# ── Optional: JWT lifetime ────────────────────────────────────────────────────
# How long a login session stays valid (hours).  Default: 720 (30 days),
# which keeps you logged in on iPhone for a month without re-entering the PIN.
# JWT_TTL_HOURS=720

# ── Live Eight Sleep Pod control (optional) ──────────────────────────────────
# By default the control daemon runs in SIMULATOR mode (no real device needed).
# To drive your actual Pod, set SLEEPCTL_LIVE=1 and provide your Eight Sleep
# account credentials below.  See deploy/LIVE_POD.md for the full bring-up.
#
# IMPORTANT: keep SLEEPCTL_DRY_RUN=1 for the first night or two — the daemon then
# reads real physiology and logs its decisions but sends NO commands to the bed.
# Set it to 0 once you're happy with what it would do.

# SLEEPCTL_LIVE=0
# SLEEPCTL_DRY_RUN=1

# Your Eight Sleep app login (the same email/password you use in the mobile app).
# EIGHTSLEEP_EMAIL=you@example.com
# EIGHTSLEEP_PASSWORD=your-eight-sleep-password
# EIGHTSLEEP_SIDE=left            # left | right (your side of the bed)
# EIGHTSLEEP_TIMEZONE=America/New_York

# Some newer Eight Sleep accounts require an OAuth2 client id/secret. If plain
# email/password fails to authenticate, see deploy/LIVE_POD.md for how to obtain
# these, then set them here.
# EIGHTSLEEP_CLIENT_ID=
# EIGHTSLEEP_CLIENT_SECRET=

# ── Optional: token-less phone-sensor ingest (trusted LAN only) ───────────────
# Drops auth on the phone endpoints ONLY (/bcg/ingest, /bcg/should-record) so an
# iPhone running Sensor Logger can stream with no token / no Auth Header. Every
# other endpoint stays login-protected. Enable this ONLY when the API is reached
# on your home network and is NOT exposed to the open internet.
# To reach the API directly from the phone at http://<server-ip>:8000, also
# publish the port — add `ports: ["8000:8000"]` to the `api` service in
# docker-compose.yml (it's unpublished by default; Caddy is the only ingress).
# BCG_INGEST_OPEN=1

# ── Optional: Web Push (critical alerts -> phone) ────────────────────────────
# When the controller goes down / thermal control stalls / the tank runs dry, the
# dashboard raises an in-app alert immediately either way (Alerts tab / GET /alerts).
# Setting these ALSO pushes a phone notification for newly-appearing CRITICAL issues,
# even if nobody has the dashboard tab open — see dashboard/api/app/push_sender.py.
#
# Generate a keypair (requires the optional `pywebpush` package — see
# dashboard/api/requirements.txt):
#   pip install pywebpush && python -m app.push_keys
# Paste the two printed lines below. NEVER commit real keys — this file only ships the
# placeholder; your actual `.env` is gitignored.
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:you@example.com
