# ──────────────────────────────────────────────────────────────────────────────
# sleepctl dashboard — environment configuration
#
# Copy this file to .env before running `make up`:
#   cp .env.example .env
#
# `make up` does that copy automatically if .env doesn't exist, and will
# also auto-generate a strong DASHBOARD_PASSWORD if it is still "changeme".
# ──────────────────────────────────────────────────────────────────────────────

# ── Auth ──────────────────────────────────────────────────────────────────────

# Single-user credentials for the dashboard login.
# `make up` replaces the placeholder password with a random one on first run.
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=changeme

# JWT signing secret.  Leave blank to auto-generate on first container start;
# the secret is then persisted to the `sleepdata` volume at /data/.jwt_secret
# so it survives restarts.  You may set an explicit value here if you prefer
# full control (run: python3 -c "import secrets; print(secrets.token_hex(32))").
JWT_SECRET=

# ── CORS ─────────────────────────────────────────────────────────────────────

# Comma-separated list of allowed origins for the FastAPI CORS middleware.
# "*" is fine for a local-only deployment.  If you add a public tunnel
# (Tailscale / Cloudflare) add its origin here.
CORS_ORIGINS=*

# ── Timezone ──────────────────────────────────────────────────────────────────

# Set to your local zone so sleep-window timestamps display correctly.
# Examples: America/New_York  America/Los_Angeles  Europe/London  Asia/Tokyo
TZ=America/New_York

# ── Optional: database path override ─────────────────────────────────────────
# Defaults to /data/sleepctl.db inside the container (backed by the sleepdata
# named volume).  Only change this if you want to mount a host path instead.
# SLEEPCTL_DB=/data/sleepctl.db

# ── Optional: JWT lifetime ────────────────────────────────────────────────────
# How long a login session stays valid (hours).  Default: 720 (30 days),
# which keeps you logged in on iPhone for a month without re-entering the PIN.
# JWT_TTL_HOURS=720
